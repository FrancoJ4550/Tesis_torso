<?xml version="1.0"?>
<launch>

  <arg name="use_takeshi"
     default="false"
     description="If true, skip hardware includes for Takeshi"/>

  <!-- === Global HW namespace === -->
  <arg name="namespace"
       default="hardware"
       description="Top-level namespace for all hardware nodes"/>

  <!-- tf_prefix típico: que coincida con el namespace -->
  <arg name="tf_prefix"
       default="$(var namespace)/"
       description="TF prefix for all hardware frames"/>

  <!-- === Robotino Arguments === -->
  <arg name="use_sim_time"
       default="false"
       description="Use simulation time (/clock)"/>

  <arg name="launch_jsb"
       default="false"
       description="Launch joint_state_publisher"/>

  <arg name="hostname"
       default="172.27.1.1"
       description="Robotino hostname or IP address"/>

  <arg name="rsp_freq"
       default="20.0"
       description="Update rate for robot_state_publisher"/>

  <arg name="bumper_timeout"
       default="0.0"
       description="Time before bumper stop triggers"/>

  <arg name="motor_timeout"
       default="0.0"
       description="Motor timeout setting"/>

  <arg name="launch_odom_tf"
       default="true"
       description="Publish odom TF frame"/>

  <!-- Robot description (Robotino xacro) -->
  <arg name="robot_description"
       default="$(find-pkg-share justina_description)/urdf/justina/justina.xacro"
       description="Path to Robotino .xacro file"
       unless="$(var use_takeshi)"/>

  <group>
    <push-ros-namespace namespace="$(var namespace)"/>

    
     <set_remap from="/$(var namespace)/base/joint_states"  to="/$(var namespace)/joint_states"/>
     <set_remap from="/$(var namespace)/head/joint_states"  to="/$(var namespace)/joint_states"/>
     <set_remap from="/$(var namespace)/arms/joint_states"   to="/$(var namespace)/joint_states"/>


     <!-- Base driver launch -->
     <include file="$(find-pkg-share base)/launch/base_driver.launch.xml"
          unless="$(var use_takeshi)">
          <arg name="namespace"         value="base"/>
          <arg name="tf_prefix"         value=""/>
          <arg name="use_sim_time"      value="$(var use_sim_time)"/>
          <arg name="launch_jsb"        value="$(var launch_jsb)"/>
          <arg name="robot_description" value="$(var robot_description)"/>
          <arg name="hostname"          value="$(var hostname)"/>
          <arg name="rsp_freq"          value="$(var rsp_freq)"/>
          <arg name="bumper_timeout"    value="$(var bumper_timeout)"/>
          <arg name="motor_timeout"     value="$(var motor_timeout)"/>
          <arg name="launch_odom_tf"    value="$(var launch_odom_tf)"/>
     </include>
  </group>

  <group>
    <push-ros-namespace namespace="$(var namespace)"/>

          <!-- === Robotino Hardware === -->
          <include file="$(find-pkg-share robotino_hardware)/launch/robotino_hardware.launch.xml" 
          unless="$(var use_takeshi)"/>
          <!-- Head -->
          <include file="$(find-pkg-share head)/launch/head.launch.xml" 
          unless="$(var use_takeshi)"/>
          
          <!-- Right Arm -->
          <include file="$(find-pkg-share arms)/launch/right_arm.launch.xml" 
          unless="$(var use_takeshi)"/>
          
          <!-- Torso -->
          <include file="$(find-pkg-share torso)/launch/torso.launch.xml" 
          unless="$(var use_takeshi)"/>


          <!-- Include Kinect pointcloud launch -->
          <include file="$(find-pkg-share kinect_ros2)/launch/kinect.launch.xml"
           unless="$(var use_takeshi)"/>
          
          <!-- Door detector -->
          <include file="$(find-pkg-share door_detector)/launch/door_detector.launch.xml" />
  </group>

  <group>
    <push-ros-namespace namespace="$(var namespace)"/>
          <!-- === Takeshi Hardware === -->
          <node pkg="hsr_hardware" 
               exec="hsr_bringup" 
               name="hsr_bringup" 
               output="screen"
               if="$(var use_takeshi)"/>
          <node pkg="hsr_hardware" 
               exec="hsr_arm_node" 
               name="hsr_arm_node" 
               output="screen"
               if="$(var use_takeshi)"/>
          <node pkg="hsr_hardware" 
               exec="hsr_head_node" 
               name="hsr_head_node" 
               output="screen"
               if="$(var use_takeshi)"/>
          <node pkg="hsr_hardware" 
               exec="hsr_talk_node" 
               name="hsr_talk_node" 
               output="screen"
               if="$(var use_takeshi)"/>
          <node pkg="hsr_hardware" 
               exec="hsr_bumper_node" 
               name="hsr_bumper_node" 
               output="screen"
               if="$(var use_takeshi)"/>

          <node
               pkg="depth_image_proc"
               exec="point_cloud_xyz_node"
               name="point_cloud_xyz"
               output="screen"
               if="$(var use_takeshi)">

               <remap from="image_rect" to="/head_rgbd_sensor/depth_registered/image_rect_raw"/>
               <remap from="camera_info" to="/head_rgbd_sensor/depth_registered/camera_info"/>
               <remap from="points" to="/hardware/camera/pointcloud2"/>

          </node>

     </group>
</launch>
