<launch>

  <!-- Argumentos configurables -->
  <arg name="port" default="/dev/jrk_torso"/>
  <arg name="baudrate" default="9600"/>
  <arg name="goal_topic" default="/hardware/torso/goal"/>

  <node
    pkg="torso"
    exec="torso_node"
    name="torso_node"
    output="screen">

    <param name="port" value="$(var port)"/>
    <param name="baudrate" value="$(var baudrate)"/>
    <param name="goal_topic" value="$(var goal_topic)"/>

  </node>

</launch>
